# --- required ---
# UW API token on the Advanced plan (WebSocket-enabled)
UW_KEY=your_unusual_whales_api_token

# Same secret gex.js uses to sign the pbj_session cookie. With this set, the
# worker only answers requests carrying a valid member session (just like gex.js).
# Leave UNSET only for local dev — that disables the auth gate.
SESSION_SECRET=your_session_secret

# --- recommended ---
# Your dashboard origin(s), comma-separated. Used for CORS. Default "*".
ALLOWED_ORIGIN=https://pbjcapital.net

# Symbols to subscribe at boot (comma-separated). These are the only symbols
# the worker streams; add the ones your members watch most.
SYMBOLS=SPX,SPY,QQQ

# --- optional ---
# Nearest expiries returned by default (the picker can request more via &exps=)
N_EXPIRIES=5

# Railway injects PORT automatically; only set locally.
# PORT=8080
